{
  "spec": {
    "template": {
      "spec": {
        "containers": [{
          "name": "nginx",
          "volumeMounts": [{
            "name": "nginx-config",
            "mountPath": "/etc/nginx/conf.d/default.conf",
            "subPath": "nginx.conf"
          }]
        }],
        "volumes": [{
          "name": "nginx-config",
          "configMap": {"name": "magicfit-nginx-laravel"}
        }]
      }
    }
  }
}
